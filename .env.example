# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL
# Replace with your real database credentials and host.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/plannerapp?schema=public"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-random-secret-here"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add http://localhost:3000/api/auth/callback/google to authorized redirect URIs
# 5. Enable Gmail API and Google Calendar API in the API Library
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: "mock" (default, no key needed) | "openai"
AI_PROVIDER="mock"
OPENAI_API_KEY=""  # Optional: only needed when AI_PROVIDER=openai

# ─── Web Push (VAPID keys) ────────────────────────────────────────────────────
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Or use: https://vapidkeys.com/
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:your-email@example.com"

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
